# ===================================================
# Cybersecurity Essentials Backend - Environment Configuration
# ===================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file with real credentials to git

# ===================================================
# SERVER CONFIGURATION
# ===================================================
PORT=5000
NODE_ENV=development
# NODE_ENV options: development, production, test

# ===================================================
# DATABASE CONFIGURATION
# ===================================================
# Option 1: Local MongoDB
# MONGODB_URI=mongodb://localhost:27017/cybersec-essentials

# Option 2: MongoDB Atlas (Cloud)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
MONGODB_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/cybersec-essentials?retryWrites=true&w=majority

# ===================================================
# JWT (JSON Web Token) CONFIGURATION
# ===================================================
# JWT_SECRET: Use a strong, random string for production
# Generate secure secret: openssl rand -base64 32
JWT_SECRET=your-very-secure-secret-key-change-this-in-production-use-at-least-32-chars
JWT_EXPIRE=7d
# JWT_EXPIRE options: 1d, 7d, 30d, 90d, etc.

# ===================================================
# CORS CONFIGURATION
# ===================================================
# Allowed origin for frontend requests
CORS_ORIGIN=http://localhost:3000
# CORS_ORIGIN=https://yourdomain.com (for production)

# ===================================================
# EMAIL CONFIGURATION (Optional - for future use)
# ===================================================
# SMTP Configuration for sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# Note: For Gmail, use App Passwords: https://myaccount.google.com/apppasswords

# ===================================================
# ADMIN CONFIGURATION
# ===================================================
# Default admin credentials for initial setup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPassword123
# Change these after first login!

# ===================================================
# OPTIONAL: LOGGING & MONITORING
# ===================================================
# LOG_LEVEL=debug
# LOG_LEVEL options: error, warn, info, debug

# ===================================================
# OPTIONAL: RATE LIMITING (for future implementation)
# ===================================================
# RATE_LIMIT_WINDOW=15 # minutes
# RATE_LIMIT_MAX_REQUESTS=100 # requests per window

# ===================================================
# CONFIGURATION NOTES
# ===================================================
# 1. DEVELOPMENT:
#    - Use localhost MongoDB or MongoDB Atlas free tier
#    - Use simple JWT_SECRET for testing
#    - CORS_ORIGIN = http://localhost:3000
#
# 2. PRODUCTION:
#    - Use strong MongoDB credentials
#    - Use strong JWT_SECRET (32+ characters, random)
#    - Enable HTTPS for CORS_ORIGIN
#    - Use environment-specific values from your hosting provider
#    - Consider using AWS Secrets Manager, Azure KeyVault, or similar
#
# 3. SECURITY BEST PRACTICES:
#    - Never commit .env with real credentials
#    - Rotate JWT_SECRET periodically
#    - Use strong, unique ADMIN_PASSWORD
#    - Enable MongoDB authentication
#    - Use HTTPS in production
#    - Keep dependencies updated

# ===================================================
# QUICK SETUP GUIDE
# ===================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values above
# 3. Start server: npm run dev
# 4. Test health: curl http://localhost:5000/api/health
